@model Testdata.Viewmodel.CustomerModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "AddCustomerdetail";
}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <h3 class="text-center mb-4">Add Customer Details</h3>

            @* Error message *@
            @if (!string.IsNullOrEmpty(ViewBag.Error as string))
            {
                <div class="alert alert-danger text-center" role="alert">
                    @ViewBag.Error
                </div>
            }
            <form id="addCustomerForm" autocomplete="off" enctype="multipart/form-data">
                <div class="form-group row">
                    <div class="col-md-6">
                        <label class="form-label">Customer Name</label>
                        <input type="hidden" id="CustomerId" name="Id" value="@Model.id" />
                        <input id="CustomerName" name="CustomerName" class="form-control" value="@Model.CustomerName" required style="border-color: #808080b0;" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Mobile Number</label>
                        <input id="CustomerMobileno" name="CustomerMobileno" class="form-control" type="tel" value="@Model.CustomerMobileno" maxlength="12" min="10" required style="border-color: #808080b0;" />
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-md-6">
                        <label class="form-label">Pincode</label>
                        <input id="CustomerPincode" name="CustomerPincode" class="form-control" value="@Model.CustomerPincode" maxlength="6" min="6" required style="border-color: #808080b0;" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input id="Email" name="Email" class="form-control" type="email" value="@Model.Email" required style="border-color: #808080b0;" />
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-md-6">
                        <label class="form-label">Profile Image</label>
                        <input type="file" id="Image" name="Image" class="form-control" accept="image/*" />
                        <input type="hidden" name="Profileimage" value="@Model.Profileimage" />
                        <img id="ImagePreview" src="@Model.Profileimage" width="80" height="80" class="mt-2" style="display: @(string.IsNullOrEmpty(Model.Profileimage) ? "none" : "block");" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Address</label>
                        <textarea id="Address" name="Address" class="form-control" required style="border-color: #808080b0;">@Model.Address</textarea>
                    </div>                 
                </div>
                <div class="col-md-12 mt-3">
                    <div class="card-body text-center py-3">
                        <button type="submit" class="btn btn-info btn-lg">Save</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
